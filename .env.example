# Backend the editor reads templates / translations / theme-structure from.
VITE_EDITOR_API_URL=https://visual-editor-be.primathontech.co.in

# Dev/QA editor builds only. When "true", a `?previewOrigin=http://localhost:3000`
# query param redirects the preview iframe at a developer's local store (gated to
# localhost/127.0.0.1). Leave unset/absent on production editor builds so the
# preview always uses the merchant's deployed URL.
VITE_ALLOW_PREVIEW_ORIGIN_OVERRIDE=false

# AI keys are NO LONGER read by the editor — generation + transcription now go
# through visual-editor-be's authed proxy (POST /api/v1/ai/generate,
# /api/v1/ai/transcribe), which injects ANTHROPIC_API_KEY / OPENAI_API_KEY
# server-side. Set those on visual-editor-be, not here.
