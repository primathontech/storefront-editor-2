# Backend the editor reads templates / translations / theme-structure from.
VITE_EDITOR_API_URL=https://visual-editor-be.primathontech.co.in

# AI keys used by EditorAPI.anthropicMessages + EditorAPI.transcribeAudio
# to call api.anthropic.com and api.openai.com directly from the browser.
# These are exposed in the editor bundle — fine for dev / internal use,
# but they should move behind a backend proxy on visual-editor-be before
# the editor is shipped beyond trusted users.
VITE_ANTHROPIC_API_KEY=your-anthropic-api-key
VITE_OPENAI_API_KEY=your-openai-api-key
